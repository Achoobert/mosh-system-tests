    "cypress": "^15.17.0",
    "cypress-if": "^1.13.2",
    "eslint": "^10.6.0",
    "globals": "^17.4.0",
    "terser-webpack-plugin": "^5.6.1",
    "webpack": "^5.76.1",
    "webpack-cli": "^7.1.0"
